
@{
    ViewData["Title"] = "ShowCategory";
}

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Category Name</th>
            <th>Description</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.CategoryName</td>
                <td>@item.Description</td>
                <td>
                    <a class="btn btn-danger btn-sm" href="/Admin/DeleteCategory/@item.CategoryId">Delete Category</a>
                </td>
                <td>
                    <a class="btn btn-danger btn-sm" href="/Admin/UpdateCategory/@item.CategoryId">Update Category</a>
                </td>
            </tr>
        }
    </tbody>
</table>

